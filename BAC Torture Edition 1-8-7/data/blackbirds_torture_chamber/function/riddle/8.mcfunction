#grant advancement if all 3 item frames are close
execute as @a[advancements={blackbirds_torture_chamber:riddle/7=true,blackbirds_torture_chamber:riddle/8=false}] at @s if entity @e[type=item_frame,distance=..10,nbt={Item:{id:"minecraft:dragon_egg",count:1}}] if entity @e[type=item_frame,distance=..10,nbt={Item:{id:"minecraft:nether_star",count:1}}] if entity @e[type=item_frame,distance=..10,nbt={Item:{components:{"minecraft:item_name":{translate:"block.minecraft.ominous_banner"},"minecraft:tooltip_display": {hidden_components: ["minecraft:banner_patterns"]},"minecraft:rarity":"uncommon","minecraft:banner_patterns":[{color:"cyan",pattern:"minecraft:rhombus"},{color:"light_gray",pattern:"minecraft:stripe_bottom"},{color:"gray",pattern:"minecraft:stripe_center"},{color:"light_gray",pattern:"minecraft:border"},{color:"black",pattern:"minecraft:stripe_middle"},{color:"light_gray",pattern:"minecraft:half_horizontal"},{color:"light_gray",pattern:"minecraft:circle"},{color:"black",pattern:"minecraft:border"}]},count:1,id:"minecraft:white_banner"}}] run advancement grant @s only blackbirds_torture_chamber:stuff/riddle_me_this_2 8
execute as @a[advancements={blackbirds_torture_chamber:riddle/7=true,blackbirds_torture_chamber:riddle/8=false}] at @s if entity @e[type=item_frame,distance=..10,nbt={Item:{id:"minecraft:dragon_egg",count:1}}] if entity @e[type=item_frame,distance=..10,nbt={Item:{id:"minecraft:nether_star",count:1}}] if entity @e[type=item_frame,distance=..10,nbt={Item:{components:{"minecraft:item_name":{translate:"block.minecraft.ominous_banner"},"minecraft:tooltip_display": {hidden_components: ["minecraft:banner_patterns"]},"minecraft:rarity":"uncommon","minecraft:banner_patterns":[{color:"cyan",pattern:"minecraft:rhombus"},{color:"light_gray",pattern:"minecraft:stripe_bottom"},{color:"gray",pattern:"minecraft:stripe_center"},{color:"light_gray",pattern:"minecraft:border"},{color:"black",pattern:"minecraft:stripe_middle"},{color:"light_gray",pattern:"minecraft:half_horizontal"},{color:"light_gray",pattern:"minecraft:circle"},{color:"black",pattern:"minecraft:border"}]},count:1,id:"minecraft:white_banner"}}] run advancement grant @s only blackbirds_torture_chamber:riddle/8

#revoke technical advancement (only if riddle 2 line 8 isn't done, otherwhise he can keep technical to not proke again)
execute as @a[advancements={blackbirds_torture_chamber:riddle/8=false}] run advancement revoke @s only blackbirds_torture_chamber:technical/make_riddle_8_work

#announce line is done
execute as @a[advancements={blackbirds_torture_chamber:riddle/8=true}] run tellraw @s {"text":"Eighth line completed","color":"gray","italic":true}